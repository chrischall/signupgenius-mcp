# signupgenius-mcp configuration
#
# Pick ONE of the two auth modes below. If both are set, the Pro API key wins
# (you'll see a warning in the startup log). Copy this file to `.env`, fill in
# real values, and never commit it — `.env` is gitignored.

# ─────────────────────────────────────────────────────────────────────────────
# Option 1 — SESSION MODE (recommended, works on free accounts)
#
# The server logs in to signupgenius.com with your real email/password the same
# way the website does, caches the resulting JWT + cookies in memory, and
# silently re-logs in on a 401. Direct accounts only — Google/Apple/Facebook/
# Microsoft SSO and 2FA are not supported.
#
# Enables every tool EXCEPT the slot-report tools (those need a Pro API key).
# ─────────────────────────────────────────────────────────────────────────────
SIGNUPGENIUS_EMAIL=you@example.com
SIGNUPGENIUS_PASSWORD=your-signupgenius-password

# ─────────────────────────────────────────────────────────────────────────────
# Option 2 — KEY MODE (Pro subscription only)
#
# Uses the documented Pro API. Pro Tools → API Management in your SignUpGenius
# account generates the key. Required to call signupgenius_report_all,
# _report_filled, _report_available — session mode has no equivalent.
# ─────────────────────────────────────────────────────────────────────────────
# SIGNUPGENIUS_USER_KEY=your-api-key-here

# ─────────────────────────────────────────────────────────────────────────────
# Optional — applies to either mode
# ─────────────────────────────────────────────────────────────────────────────

# Friendly label shown in the server's startup log. Defaults to your email
# (session mode) or the API hostname (key mode).
# SIGNUPGENIUS_NAME=Family

# Override the JSON API base. Defaults:
#   key mode    → https://api.signupgenius.com/v2/k
#   session mode → https://api.signupgenius.com/v3
# Only set this if SignUpGenius support gives you a different host.
# SIGNUPGENIUS_BASE_URL=https://api.signupgenius.com/v3

# Session mode only: override the legacy SUGboxAPI dispatcher host.
# Defaults to https://www.signupgenius.com
# SIGNUPGENIUS_LEGACY_BASE_URL=https://www.signupgenius.com

# Session mode only: override the login form host.
# Defaults to https://www.signupgenius.com
# SIGNUPGENIUS_LOGIN_URL=https://www.signupgenius.com
